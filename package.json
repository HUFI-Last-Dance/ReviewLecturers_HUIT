{
  "name": "review-lecturers-monorepo",
  "private": true,
  "description": "Monorepo for ReviewLecturers project",
  "workspaces": [
    "backend",
    "frontend",
    "mobile"
  ],
  "scripts": {
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { try { require('child_process').execSync('husky', {stdio: 'inherit'}) } catch (e) {} }\"",
    "test:all": "npm test --workspaces --if-present",
    "type-check:all": "npm run type-check --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:mobile": "npm run type-check --workspace=mobile",
    "lint:all": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:mobile": "npm run start --workspace=mobile"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "backend/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "npm test --workspace=backend -- --findRelatedTests --passWithNoTests"
    ],
    "frontend/**/*.{js,ts,tsx}": [
      "prettier --write",
      "cross-env ESLINT_USE_FLAT_CONFIG=true eslint --config frontend/eslint.config.mjs --fix"
    ],
    "mobile/**/*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
