# ========================================
# 🔐 ENVIRONMENT VARIABLES - Backend (Template)
# ========================================

# 🗄️ DATABASE (Lấy link thật từ chủ dự án)
# Định dạng: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://username:password@your-neon-hostname.aws.neon.tech/neondb?sslmode=require"

# 🔑 JWT SECURITY
# Dùng để mã hóa token đăng nhập, nên đặt một chuỗi dài và khó đoán
JWT_SECRET="your_super_secret_jwt_key_here_change_me"
JWT_EXPIRES_IN="7d"

# 🌐 SERVER CONFIG
PORT=5000
NODE_ENV="development"
